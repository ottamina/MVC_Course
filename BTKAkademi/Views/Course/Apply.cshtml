@model Candidate


<div class="display-6">
    Apply
</div>

<form method="post" asp-controller="Course" asp-action="Apply">
    
    <div class="text-danger" asp-validation-summary="All"></div>


    <div class="form-group my-2">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="form-group my-2">
        <label asp-for="FirstName"></label>
        <input asp-for="FirstName" class="form-control" />
    </div>

    <div class="form-group my-2">
        <label asp-for="LastName"></label>
        <input asp-for="LastName" class="form-control" />
    </div>

    <div class="form-group my-2">
        <label asp-for="Age"></label>
        <select asp-for="Age" class="form-control">
            <option value="18">18</option>
            <option value="19">19</option>
            <option value="20">20</option>
            <option value="21">21</option>
            <option value="22">22</option>
            <option value="23">23</option>
            <option value="24">24</option>
            <option value="25">25</option>
        </select>
    </div>

    <fieldset>
        <legend>Select One Course</legend>
        <p>
            <input type="radio" asp-for="SelectedCourse" id="mvc" value="ASP.NET CORE MVC" checked />
            <label>ASP.NET CORE MVC</label>
        </p>

        <p>
            <input type="radio" asp-for="SelectedCourse" id="api" value="ASP.NET CORE API" />
            <label>ASP.NET CORE API</label>
        </p>

        <p>
            <input type="radio" asp-for="SelectedCourse" id="blazor" value="Blazor" />
            <label>Blazor</label>
        </p>
    </fieldset>

    <div>
        <button type="submit" class="btn btn-primary">Apply</button>
        <a class="btn btn-warning" asp-controller="Home" asp-action="Index">Home</a>
    </div>



</form>